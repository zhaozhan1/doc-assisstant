# ===== 依赖目录 =====
# 这些目录包含大量第三方代码，不需要 Claude 读取
node_modules/
.eggs/
*.egg-info/

# ===== 构建产物 =====
# 生成的文件，不包含源代码信息
dist/
build/
*.pyc
__pycache__/
*.egg

# ===== 前端构建产物 =====
.next/
out/
*.tsbuildinfo

# ===== 日志文件 =====
# 运行时生成的日志，对理解项目无帮助
*.log
logs/

# ===== 测试相关 =====
# 测试覆盖率报告
coverage/
.nyc_output/
htmlcov/
.pytest_cache/
.mypy_cache/

# ===== 数据目录 =====
# 运行时生成的向量数据库和元数据，体积大且为二进制
data/

# ===== 输出目录 =====
# 用户生成的公文输出文件
output/

# ===== 编辑器/IDE =====
# 编辑器配置和临时文件
.vscode/
.idea/
*.suo
*.sw?
*.swp

# ===== 系统文件 =====
.DS_Store
Thumbs.db

# ===== 环境变量 =====
# 包含敏感信息（API Key 等），不应被读取
.env
.env.local
.env.*.local

# ===== 锁文件 =====
# 不需要 Claude 分析依赖版本锁定
package-lock.json
pnpm-lock.yaml

# ===== Conda 环境 =====
# 虚拟环境目录，体积大
.conda/
venv/
.venv/
